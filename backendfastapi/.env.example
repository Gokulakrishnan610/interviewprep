# FastAPI Settings
APP_NAME="Interview Prep AI API"
VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=True
HOST="0.0.0.0"
PORT=8001

# Database (SQLite)
DATABASE_URL="sqlite:///./interview_ai.db"

# Security
SECRET_KEY="your-super-secret-key-change-this"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# LiveKit
LIVEKIT_URL="your-livekit-url"
LIVEKIT_API_KEY="your-livekit-api-key"
LIVEKIT_API_SECRET="your-livekit-secret"

# AI Services
GOOGLE_API_KEY="your-google-api-key"
DEEPGRAM_API_KEY="your-deepgram-api-key"
GOOGLE_CLOUD_PROJECT_ID="your-google-cloud-project-id"
GOOGLE_CLOUD_CREDENTIALS_FILE="path/to/credentials.json"

# Beyond Presence
BEYOND_PRESENCE_API_KEY="your-beyond-presence-api-key"
BEYOND_PRESENCE_API_URL="https://api.beyondpresence.com/v1"

# Hugging Face
HUGGING_FACE_API_KEY="your-huggingface-api-key"

# Redis Cache
REDIS_URL="redis://localhost:6379"