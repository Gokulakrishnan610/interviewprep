# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME="Interview Prep AI"
VERSION="2.0.0"
ENVIRONMENT=development
DEBUG=True
HOST=0.0.0.0
PORT=8001

# ── Database (async PostgreSQL) ────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://interview:interview@localhost:5432/interview_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@interviewprep.local
DEFAULT_FROM_NAME="Interview Prep AI"

# ── LiveKit ────────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# ── Google Gemini ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key

# ── Deepgram ───────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Azure Speech ───────────────────────────────────────────────────────────────
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=centralindia
AZURE_TTS_VOICE=en-US-JennyNeural

# ── Beyond Presence (avatar) ───────────────────────────────────────────────────
BEYOND_PRESENCE_API_KEY=your-beyond-presence-api-key
BEYOND_PRESENCE_API_URL=https://api.bey.dev/v1

# ── Hugging Face ───────────────────────────────────────────────────────────────
HUGGING_FACE_API_KEY=your-hf-api-key
HF_ZERO_SHOT_MODEL=facebook/bart-large-mnli
HF_API_BASE_URL=https://api-inference.huggingface.co/models
